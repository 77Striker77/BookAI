#!/usr/bin/env bash
# ============================================================================
# EIN-BRANCH-VERRIEGELUNG (harte Regel des Nutzers, 2026-07-20)
# Erlaubt Pushes AUSSCHLIESSLICH auf den einen Arbeits-Branch.
# Jeder Versuch, auf einen anderen Branch zu pushen (= faktisch einen neuen
# Branch anzulegen), wird blockiert und laut gemeldet ("Alarm").
# ============================================================================
ALLOWED_BRANCH="claude/books-library-feedback-rhkjwj"
ALLOWED_REF="refs/heads/${ALLOWED_BRANCH}"

status=0
while read -r local_ref local_sha remote_ref remote_sha; do
  # Leere Zeile / Löschung ohne Ref überspringen
  [ -z "$remote_ref" ] && continue
  if [ "$remote_ref" != "$ALLOWED_REF" ]; then
    echo "" >&2
    echo "🚨🔒 ALARM — PUSH BLOCKIERT (Ein-Branch-Verriegelung)" >&2
    echo "   Ziel:    $remote_ref" >&2
    echo "   Erlaubt: $ALLOWED_REF" >&2
    echo "   Es darf NUR auf den einen Branch '$ALLOWED_BRANCH' gepusht werden." >&2
    echo "   Kein neuer Branch. Nie. (Regel vom 2026-07-20.)" >&2
    echo "" >&2
    status=1
  fi
done

exit $status
